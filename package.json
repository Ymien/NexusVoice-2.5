{
  "name": "workspace",
  "private": true,
  "version": "0.6.50",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ymien/NexusVoice-2.5.git"
  },
  "main": "electron-main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"cross-env BROWSER=none npm run dev\" \"npm run electron:start\"",
    "electron:start": "wait-on http://localhost:5173 && electron .",
    "electron:build": "vite build && electron-builder",
    "check": "tsc -b --noEmit"
  },
  "build": {
    "appId": "com.nexusvoice.app",
    "productName": "NexusVoice",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Ymien",
        "repo": "NexusVoice-2.5"
      }
    ],
    "files": [
      "dist/**/*",
      "electron-main.js"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/vite.svg"
    }
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "@supabase/supabase-js": "^2.102.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.3.0",
    "tailwind-merge": "^3.0.2",
    "zustand": "^5.0.12",
    "@capacitor/android": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "wait-on": "^8.0.1",
    "@eslint/js": "^9.25.0",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-dev-locator": "^1.0.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
